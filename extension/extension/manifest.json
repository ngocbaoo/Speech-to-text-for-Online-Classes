{
  "manifest_version": 3,
  "name": "IELTS Live Transcript",
  "version": "2.0.0",
  "description": "Real-time bilingual subtitles — Whisper AI (VI/EN)",
  "permissions": ["tabCapture", "offscreen", "tabs", "scripting"],
  "host_permissions": ["ws://localhost:8765/*", "<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" }
}